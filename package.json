{
  "name": "paper-digest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "send-digest": "node --import tsx src/commands/sendDigest.ts",
    "write-preview": "node --import tsx src/commands/writeDigestPreview.ts",
    "daily": "npm run dev && npm run send-digest && npm run write-preview",
    "test-routing-llm": "node --import tsx src/commands/testRoutingLlm.ts",
    "test-digest-llm": "node --import tsx src/commands/testDigestLlm.ts",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "export-regression-fixture": "node --import tsx src/commands/exportRegressionFixture.ts",
    "snapshot-rss": "node --import tsx src/commands/snapshotRss.ts",
    "prune-retention": "node --import tsx src/commands/pruneRetention.ts",
    "test": "node --import tsx --test 'test/**/*.test.ts'",
    "test:e2e": "node --import tsx --test test/e2e/*.test.ts",
    "test:regression": "node --import tsx --test test/regression/*.test.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "openai": "^6.39.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
