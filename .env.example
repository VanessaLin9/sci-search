# Copy to .env (gitignored): cp .env.example .env
#
# Verbose pipeline logs (normalize tables, enrich per-paper, classified samples).
# Use 1 or true to enable; omit or 0 for cron-friendly output.
DEBUG_NORMALIZED=0

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
# Sender display + address: config/email.json (commit to repo)
# Optional overrides:
# DIGEST_FROM_EMAIL=onboarding@resend.dev
# DIGEST_FROM_NAME=每日科學期刊摘要
# DIGEST_SUBJECT_PREFIX=每日科學期刊摘要
# With @resend.dev sender, only this inbox can receive mail (others are skipped with a warning)
# RESEND_ACCOUNT_EMAIL=you@example.com
# Recipients: JSON array (recommended) or comma-separated
DIGEST_TO_EMAIL=["you@example.com","mentor@example.com"]
# DIGEST_TO_EMAIL=you@example.com,mentor@example.com
# Optional subject prefix (default: Paper Digest)
# DIGEST_SUBJECT_PREFIX=Paper Digest

# Phase 2a: life-science routing (see config/routing.json for endpoint, batch, tokens)
# ROUTE_LIFE_SCIENCE=1
# ROUTING_LLM_API_KEY=...               # or legacy NVIDIA_API_KEY / OPENAI_API_KEY
# ROUTING_LLM_MODEL=your-routing-model  # private — not in repo; use Actions secret in CI

# Phase 2b: digest line + featured 12 + 繁中 summary (see config/digest.json)
# ENABLE_LLM_DIGEST=1
# DIGEST_LLM_API_KEY=...                # optional; falls back to ROUTING_LLM_API_KEY
# DIGEST_LLM_MODEL=minimaxai/minimax-m2.7   # often same as routing; required when digest is on
#
# Full local run: npm run daily
# Smoke-test one paper:
# npm run test-routing-llm
# npm run test-digest-llm
# npm run test-digest-llm -- --use-routing
