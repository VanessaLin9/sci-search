# Copy to .env (gitignored): cp .env.example .env
#
# Verbose pipeline logs (normalize tables, enrich per-paper, classified samples).
# Use 1 or true to enable; omit or 0 for cron-friendly output.
DEBUG_NORMALIZED=0

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx
# Resend free tier: use onboarding@resend.dev until your domain is verified
DIGEST_FROM_EMAIL=onboarding@resend.dev
# Recipients: JSON array (recommended) or comma-separated
DIGEST_TO_EMAIL=["you@example.com","mentor@example.com"]
# DIGEST_TO_EMAIL=you@example.com,mentor@example.com
# Optional subject prefix (default: Paper Digest)
# DIGEST_SUBJECT_PREFIX=Paper Digest

# Phase 2a: life-science routing (broad-science sources → title-only LLM gate)
# ROUTE_LIFE_SCIENCE=1
# ROUTING_LLM_API_KEY=...             # or NVIDIA_API_KEY or OPENAI_API_KEY
# ROUTING_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# ROUTING_LLM_MODEL=z-ai/glm-5.1
# ROUTING_LLM_BATCH_SIZE=25
# ROUTING_LLM_ENABLE_THINKING=0       # NVIDIA GLM: keep off for routing (saves tokens)
#
# OpenAI example:
# ROUTING_LLM_BASE_URL=https://api.openai.com/v1
# ROUTING_LLM_MODEL=gpt-4o-mini
